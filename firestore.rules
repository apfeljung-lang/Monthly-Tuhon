rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId} (Firebase Auth UID)
    // Fields:
    //   - uid: string (required)
    //   - displayName: string (required)
    //   - photoURL: string (optional)
    //   - totalAssets: number (required)
    //   - monthlyReturn: number
    //   - monthlyProfit: number
    //   - tuhonScore: number
    //   - role: string (default: 'user')
    //
    // Collection: posts
    // Document ID: {postId}
    // Fields:
    //   - authorUid: string (required)
    //   - authorName: string (required)
    //   - content: string (required, max 1000 chars)
    //   - createdAt: timestamp (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         request.auth.token.email == "apfeljung@gmail.com");
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'displayName', 'totalAssets']) &&
             data.uid is string && data.uid == request.auth.uid &&
             data.displayName is string && data.displayName.size() > 0 && data.displayName.size() < 100 &&
             data.totalAssets is number;
    }

    function isValidPost(data) {
      return data.keys().hasAll(['authorUid', 'authorName', 'content', 'createdAt']) &&
             data.authorUid == request.auth.uid &&
             data.authorName is string && data.authorName.size() > 0 &&
             data.content is string && data.content.size() > 0 && data.content.size() <= 1000 &&
             data.createdAt is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    // Users collection
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.role == 'user';
      allow update: if isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.role == resource.data.role;
      allow delete: if isAdmin();

      // Subcollections
      match /portfolio/{holdingId} {
        allow read: if isAuthenticated();
        allow write: if isOwner(userId);
      }
      
      match /trades/{tradeId} {
        allow read: if isAuthenticated();
        allow write: if isOwner(userId);
      }
    }

    // Posts collection
    match /posts/{postId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidPost(request.resource.data);
      allow update: if isAuthenticated() && (request.auth.uid == resource.data.authorUid || isAdmin());
      allow delete: if isAuthenticated() && (request.auth.uid == resource.data.authorUid || isAdmin());

      // Comments subcollection
      match /comments/{commentId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated();
        allow delete: if isAuthenticated() && (request.auth.uid == resource.data.authorUid || isAdmin());
      }
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
