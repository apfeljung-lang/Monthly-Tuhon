rules_version = '2';
service cloud.firestore {
  match /databases/ai-studio-ef7362eb-ec19-4c2a-94a2-47b4c1d8417f/documents {
    // 모든 인증된 사용자에게 자신의 문서에 대한 읽기/쓰기 허용
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // 기타 컬렉션에 대한 기본 규칙 (필요에 따라 확장 가능)
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
  
  match /databases/(default)/documents {
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
